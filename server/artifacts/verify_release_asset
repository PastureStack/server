#!/bin/bash
set -euo pipefail

checksum_file="${1:?checksum file is required}"
asset_path="${2:?asset path is required}"

test -f "${checksum_file}"
test -f "${asset_path}"

asset_name="${3:-$(basename -- "${asset_path}")}"
if ! [[ "${asset_name}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    echo "Invalid release asset name: ${asset_name}" >&2
    exit 1
fi

mapfile -t expected_hashes < <(
    awk -v expected_name="${asset_name}" '
        {
            listed_name = $2
            sub(/^\*/, "", listed_name)
            if (listed_name == expected_name) {
                print $1
            }
        }
    ' "${checksum_file}"
)

if [ "${#expected_hashes[@]}" -ne 1 ]; then
    echo "Expected exactly one SHA-256 entry for ${asset_name}" >&2
    exit 1
fi
if ! [[ "${expected_hashes[0]}" =~ ^[0-9a-f]{64}$ ]]; then
    echo "Invalid SHA-256 entry for ${asset_name}" >&2
    exit 1
fi

printf '%s  %s\n' "${expected_hashes[0]}" "${asset_path}" | sha256sum -c -
